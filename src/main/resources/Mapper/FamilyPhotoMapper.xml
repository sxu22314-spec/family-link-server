<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.linkfamily.Mapper.FamilyPhotoMapper">

    <!-- Query photos by filters with pagination -->
    <select id="queryByFilters" resultType="com.example.linkfamily.Model.Entity.Photo">
        SELECT * FROM tb_photo
        WHERE type = 1 OR type = 2
        <if test="theme != null and theme != ''">
            AND theme = #{theme}
        </if>
        <if test="dateFrom != null">
            AND photo_date >= #{dateFrom}
        </if>
        <if test="dateTo != null">
            AND photo_date <![CDATA[<=]]> #{dateTo}
        </if>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- Count photos by filters -->
    <select id="countByFilters" resultType="int">
        SELECT COUNT(*) FROM tb_photo
        WHERE type = 1 OR type = 2
        <if test="theme != null and theme != ''">
            AND theme = #{theme}
        </if>
        <if test="dateFrom != null">
            AND photo_date >= #{dateFrom}
        </if>
        <if test="dateTo != null">
            AND photo_date <![CDATA[<=]]> #{dateTo}
        </if>
    </select>

    <!-- Query photos by date range -->
    <select id="queryByDateRange" resultType="com.example.linkfamily.Model.Entity.Photo">
        SELECT * FROM tb_photo
        WHERE type = 2 OR type = 1
        <if test="dateFrom != null">
            AND photo_date >= #{dateFrom}
        </if>
        <if test="dateTo != null">
            AND photo_date <![CDATA[<=]]> #{dateTo}
        </if>
        ORDER BY create_time DESC
    </select>

    <!-- Query photos by theme -->
    <select id="queryByTheme" resultType="com.example.linkfamily.Model.Entity.Photo">
        SELECT * FROM tb_photo
        WHERE type = 2 OR type = 1
        <if test="theme != null and theme != ''">
            AND theme = #{theme}
        </if>
        ORDER BY create_time DESC
    </select>

    <!-- Find photo by id -->
    <select id="findById" resultType="com.example.linkfamily.Model.Entity.Photo">
        SELECT * FROM tb_photo WHERE id = #{id}
    </select>

    <!-- Delete photo by id -->
    <delete id="deleteById">
        DELETE FROM tb_photo WHERE id = #{id}
    </delete>

</mapper>
